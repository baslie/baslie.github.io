---
import Article from '../layouts/Article.astro';
import ExternalLinkIcon from './ExternalLinkIcon.astro';

interface Props {
  title: string;
  description: string;
  ogTitle: string;
  ogDescription: string;
  ogImage: string;
  ogUrl: string;
  articleId: string;
  h1: string;
  metaRu: string;
  metaEn: string;
  bodyRu: string;
  bodyEn: string;
  tech: string;
  siteUrl: string;
  siteDisplay: string;
  screenshotUrl: string;
  screenshotAltRu: string;
  screenshotAltEn: string;
  datePublished: string;
  dateModified?: string;
}

const {
  title, description, ogTitle, ogDescription, ogImage, ogUrl,
  articleId, h1, metaRu, metaEn,
  bodyRu, bodyEn, tech, siteUrl, siteDisplay,
  screenshotUrl, screenshotAltRu, screenshotAltEn,
  datePublished, dateModified,
} = Astro.props;

const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": ogTitle || title,
  "description": ogDescription || description,
  "image": ogImage,
  "url": ogUrl,
  "datePublished": datePublished,
  "dateModified": dateModified || datePublished,
  "author": { "@type": "Person", "name": "Роман Пуртов", "url": "https://roman-purtow.ru" },
  "publisher": {
    "@type": "Person",
    "name": "Роман Пуртов",
    "url": "https://roman-purtow.ru",
    "logo": {
      "@type": "ImageObject",
      "url": "https://roman-purtow.ru/images/favicon.png"
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": ogUrl
  }
};
---

<Article
  title={title}
  description={description}
  ogTitle={ogTitle}
  ogDescription={ogDescription}
  ogImage={ogImage}
  ogUrl={ogUrl}
  jsonLd={articleJsonLd}
>
    <header class="article-header">
        <h1 class="article-title" data-i18n={`article_${articleId}_title`} set:html={h1} />
        <span data-i18n-content="ru"><p class="article-meta" set:html={metaRu} /></span>
        <span data-i18n-content="en" style="display:none"><p class="article-meta" set:html={metaEn} /></span>
    </header>

    <div class="article-body" data-i18n-content="ru">
        <p set:html={bodyRu} />

        <p><strong>Технологии:</strong> {tech}</p>

        <a class="article-site-link" href={siteUrl} rel="nofollow noopener noreferrer" target="_blank">
            <ExternalLinkIcon />
            {siteDisplay}
        </a>

        <a href={siteUrl} rel="nofollow noopener noreferrer" target="_blank"><img src={screenshotUrl} alt={screenshotAltRu} loading="lazy" decoding="async"></a>
    </div>

    <div class="article-body" data-i18n-content="en" style="display:none">
        <p set:html={bodyEn} />

        <p><strong>Technologies:</strong> {tech}</p>

        <a class="article-site-link" href={siteUrl} rel="nofollow noopener noreferrer" target="_blank">
            <ExternalLinkIcon />
            {siteDisplay}
        </a>

        <a href={siteUrl} rel="nofollow noopener noreferrer" target="_blank"><img src={screenshotUrl} alt={screenshotAltEn} loading="lazy" decoding="async"></a>
    </div>
</Article>
