---
import Article from '../layouts/Article.astro';
import ExternalLinkIcon from './ExternalLinkIcon.astro';
import { useTranslations, type AlternateLinks } from '../i18n/utils';
import { htmlLang, type Lang } from '../i18n/ui';
import type { Article as ArticleData } from '../data/articles';

interface Props {
  article: ArticleData;
  lang: Lang;
  canonical: string;
  alternates: AlternateLinks;
}

const { article, lang, canonical, alternates } = Astro.props;
const t = useTranslations(lang);
const localized = article[lang];

const ogImageAbsolute = `https://roman-purtow.ru${article.image}`;
const homePath = lang === 'en' ? '/en/' : '/';
const homeName = lang === 'en' ? 'Home' : 'Главная';
const headlinePlain = localized.h1.replace(/<[^>]+>/g, ' ').replace(/\s+/g, ' ').trim();

const articleJsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": localized.ogTitle,
      "description": localized.ogDescription,
      "image": ogImageAbsolute,
      "url": canonical,
      "inLanguage": htmlLang[lang],
      "datePublished": article.datePublished,
      "dateModified": article.dateModified || article.datePublished,
      "author": { "@type": "Person", "name": "Роман Пуртов", "url": "https://roman-purtow.ru" },
      "publisher": {
        "@type": "Person",
        "name": "Роман Пуртов",
        "url": "https://roman-purtow.ru",
        "image": "https://roman-purtow.ru/images/favicon.png"
      },
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": canonical
      }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": homeName, "item": `https://roman-purtow.ru${homePath}` },
        { "@type": "ListItem", "position": 2, "name": headlinePlain, "item": canonical }
      ]
    }
  ]
};
---

<Article
  title={localized.title}
  description={localized.description}
  ogTitle={localized.ogTitle}
  ogDescription={localized.ogDescription}
  ogImage={ogImageAbsolute}
  ogUrl={canonical}
  jsonLd={articleJsonLd}
  lang={lang}
  alternates={alternates}
  canonical={canonical}
>
    <header class="article-header">
        <h1 class="article-title" set:html={localized.h1} />
        <p class="article-meta" set:html={localized.metaLine} />
    </header>

    <div class="article-body">
        <p set:html={localized.body} />

        {article.tech && (
            <p><strong>{t('tech.label')}:</strong> {article.tech}</p>
        )}

        {article.siteUrl && article.siteDisplay && (
            <a class="article-site-link" href={article.siteUrl} rel="nofollow noopener noreferrer" target="_blank">
                <ExternalLinkIcon />
                {article.siteDisplay}
            </a>
        )}

        {article.screenshotUrl && article.siteUrl && (
            <a href={article.siteUrl} rel="nofollow noopener noreferrer" target="_blank"><img src={article.screenshotUrl} alt={localized.screenshotAlt} loading="lazy"></a>
        )}
    </div>
</Article>
