---
interface Props {
    showLang?: boolean;
    homeLink?: boolean;
}
const { showLang = true, homeLink = false } = Astro.props;

const logoSvg = `<svg viewBox="0 0 90 100" fill="none" xmlns="http://www.w3.org/2000/svg">
