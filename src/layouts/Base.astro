---
import '../styles/input.css';
import { useTranslations, type AlternateLinks } from '../i18n/utils';
import { htmlLang, ogLocale, type Lang } from '../i18n/ui';

interface Props {
  title: string;
  description: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  ogUrl?: string;
  ogType?: string;
  canonical?: string;
  twitterCard?: string;
  noPreload?: boolean;
  noindex?: boolean;
  jsonLd?: Record<string, unknown>;
  lang?: Lang;
  alternates?: AlternateLinks;
}

const {
  title,
  description,
  ogTitle,
  ogDescription,
  ogImage = 'https://roman-purtow.ru/images/preview.jpg',
  ogUrl = 'https://roman-purtow.ru/',
  ogType = 'website',
  canonical = 'https://roman-purtow.ru/',
  twitterCard = 'summary_large_image',
  noPreload = false,
  noindex = false,
  jsonLd,
  lang = 'ru',
  alternates,
} = Astro.props;

const t = useTranslations(lang);
const finalOgTitle = ogTitle || title;
const finalOgDescription = ogDescription || description;
const altLocale = lang === 'ru' ? 'en' : 'ru';
---

<!DOCTYPE html>
<html lang={htmlLang[lang]} itemscope itemtype="https://schema.org/WebPage">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content={description}>
    <meta name="robots" content={noindex ? 'noindex, follow' : 'index, follow'}>
    <meta name="author" content="Роман Пуртов">
    <meta name="yandex-verification" content="baba7a3a035222ee">
    <meta name="zen-verification" content="1VfsUNzrT2kKSoOR3uOBbHlA9rlA0pG8FPICtKqMtotDTKR0rchMKpVBsJMXVnzN">
    <meta name="p:domain_verify" content="2432aa039334ba49c34ecfd71d5b3c04">
    <title>{title}</title>
    <link rel="icon" href="/images/favicon.svg" type="image/svg+xml">
    <link rel="icon" href="/images/favicon.png" type="image/png">
    <link rel="apple-touch-icon" sizes="180x180" href="/images/apple-touch-icon.png">
    <meta name="theme-color" content="#222222">
    <script is:inline>
      if(localStorage.getItem('theme')==='dark'){document.documentElement.classList.add('dark')}
    </script>
    <link rel="canonical" href={canonical}>
    {alternates && (
      <>
        <link rel="alternate" hreflang="ru" href={alternates.ru} />
        <link rel="alternate" hreflang="en" href={alternates.en} />
        <link rel="alternate" hreflang="x-default" href={alternates.xDefault} />
      </>
    )}

    <meta property="og:title" content={finalOgTitle}>
    <meta property="og:description" content={finalOgDescription}>
    <meta property="og:image" content={ogImage}>
    <meta property="og:url" content={ogUrl}>
    <meta property="og:type" content={ogType}>
    <meta property="og:site_name" content="Роман Пуртов">
    <meta property="og:locale" content={ogLocale[lang]}>
    <meta property="og:locale:alternate" content={ogLocale[altLocale]}>
    <meta name="twitter:card" content={twitterCard}>
    <meta name="twitter:title" content={finalOgTitle}>
    <meta name="twitter:description" content={finalOgDescription}>
    <meta name="twitter:image" content={ogImage}>

    <!-- Preload LCP image (only on main page) -->
    {!noPreload && <link rel="preload" as="image" href="/images/roman.webp" type="image/webp">}

    <!-- Additional head content from child layouts -->
    <slot name="head" />

    <!-- Schema.org -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd || {
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Роман Пуртов",
      "alternateName": "Roman Purtov",
      "url": "https://roman-purtow.ru",
      "image": "https://roman-purtow.ru/images/roman.jpg",
      "jobTitle": "Маркетолог, UX/UI дизайнер и веб-разработчик",
      "worksFor": { "@type": "Organization", "name": "Freelance" },
      "address": { "@type": "PostalAddress", "addressLocality": "Томск", "addressCountry": "RU" },
      "sameAs": [
        "https://github.com/baslie",
        "https://t.me/roman_purtow",
        "https://instagram.com/roman.purtow",
        "https://vk.com/roman_purtow",
        "https://www.youtube.com/@roman-purtow",
        "https://vc.ru/u/454432-roman-purtov"
      ]
    })} />
</head>

<body class="font-sans antialiased" data-copied-text={t('copy.tooltip')}>
    <!-- Фоновое видео -->
    <video id="background-video" autoplay muted loop playsinline poster="/images/bg.webp">
        <source src="/videos/bg.mp4" type="video/mp4">
        <img src="/images/bg.webp" alt="" style="width: 100%; height: 100%; object-fit: cover;">
    </video>

    <slot />

    <!-- Lenis Smooth Scroll -->
    <script is:inline src="/js/lenis.min.js" defer></script>

    <!-- Main Application Script -->
    <script is:inline src="/js/app.js" defer></script>
</body>

</html>
