---
import Base from './Base.astro';
import CornerNav from '../components/CornerNav.astro';

interface Props {
  title: string;
  description: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  ogUrl?: string;
  jsonLd?: Record<string, unknown>;
}

const {
  title,
  description,
  ogTitle,
  ogDescription,
  ogImage,
  ogUrl,
  jsonLd,
} = Astro.props;
---

<Base
  title={title}
  description={description}
  ogTitle={ogTitle}
  ogDescription={ogDescription}
  ogImage={ogImage}
  ogUrl={ogUrl}
  ogType="article"
  canonical={ogUrl}
  noPreload={true}
  jsonLd={jsonLd}
>
  <Fragment slot="head">
    <script is:inline>
      if(localStorage.getItem('lang')==='en'){document.documentElement.classList.add('lang-en')}
    </script>
    <style is:inline>
      html.lang-en [data-i18n-content="ru"]{display:none}
      html.lang-en [data-i18n-content="en"]{display:block!important}
    </style>
  </Fragment>

  <CornerNav showLang={true} homeLink={true} />

  <article class="article-container">
      <a href="/" class="article-back">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
          <span data-i18n="article_back">На главную</span>
      </a>

      <slot />

      <a href="/" class="article-back article-back--bottom">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
          <span data-i18n="article_back">На главную</span>
      </a>
  </article>
</Base>

<style>
    body {
        background: url('/images/bg.webp') no-repeat center center fixed;
        background-size: cover;
        min-height: 100vh;
    }

    @media (max-width: 768px) {
        body {
            background-attachment: scroll;
        }
    }

    .article-container {
        max-width: 720px;
        margin: 1rem auto 2rem;
        padding: 2.5rem 2.5rem 4rem;
        background: var(--card-bg);
        border-radius: var(--radius);
        box-shadow: var(--shadow);
    }

    :global(.dark) .article-container {
        background: var(--card-bg-dark);
        box-shadow: 0 4px 30px var(--card-shadow-dark);
    }

    .article-back {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        color: var(--color-text-muted);
        text-decoration: none;
        font-size: 0.875rem;
        margin-bottom: 2rem;
        transition: color 0.2s ease;
    }

    .article-back:hover {
        color: var(--color-link);
    }

    :global(.dark) .article-back {
        color: rgba(255, 255, 255, 0.5);
    }

    :global(.dark) .article-back:hover {
        color: var(--color-link);
    }

    @media (max-width: 767px) {
        .article-container {
            max-width: 100%;
            margin: 0;
            padding: 1.5rem 1rem 3rem;
            border-radius: 0;
            box-shadow: none;
        }

        :global(.dark) .article-container {
            box-shadow: none;
        }
    }
</style>
