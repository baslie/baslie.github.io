---
import Base from './Base.astro';
import CornerNav from '../components/CornerNav.astro';
import { useTranslations, type AlternateLinks } from '../i18n/utils';
import type { Lang } from '../i18n/ui';

interface Props {
  title: string;
  description: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  ogUrl?: string;
  jsonLd?: Record<string, unknown>;
  lang: Lang;
  alternates: AlternateLinks;
  canonical: string;
}

const {
  title,
  description,
  ogTitle,
  ogDescription,
  ogImage,
  ogUrl,
  jsonLd,
  lang,
  alternates,
  canonical,
} = Astro.props;

const t = useTranslations(lang);
const homeHref = lang === 'en' ? '/en/' : '/';
const currentPath = Astro.url.pathname;
---

<Base
  title={title}
  description={description}
  ogTitle={ogTitle}
  ogDescription={ogDescription}
  ogImage={ogImage}
  ogUrl={ogUrl ?? canonical}
  ogType="article"
  canonical={canonical}
  noPreload={true}
  jsonLd={jsonLd}
  lang={lang}
  alternates={alternates}
>
  <CornerNav lang={lang} currentPath={currentPath} showLang={true} homeLink={true} />

  <article class="article-container">
      <a href={homeHref} class="article-back">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
          <span>{t('article.back')}</span>
      </a>

      <slot />

      <a href={homeHref} class="article-back article-back--bottom">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
          <span>{t('article.back')}</span>
      </a>
  </article>
</Base>

<style>
    body {
        min-height: 100vh;
    }

    .article-container {
        max-width: 720px;
        margin: 1rem auto 2rem;
        padding: 2.5rem 2.5rem 4rem;
        background: var(--card-bg);
        border-radius: var(--radius);
        box-shadow: var(--shadow);
    }

    :global(.dark) .article-container {
        background: var(--card-bg-dark);
        box-shadow: 0 4px 30px var(--card-shadow-dark);
    }

    .article-back {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        color: var(--color-text-muted);
        text-decoration: none;
        font-size: 0.875rem;
        margin-bottom: 2rem;
        transition: color 0.2s ease;
    }

    .article-back:hover {
        color: var(--color-link);
    }

    :global(.dark) .article-back {
        color: rgba(255, 255, 255, 0.5);
    }

    :global(.dark) .article-back:hover {
        color: var(--color-link);
    }

    @media (max-width: 767px) {
        .article-container {
            max-width: 100%;
            margin: 0;
            padding: 1.5rem 1rem 3rem;
            border-radius: 0;
            box-shadow: none;
        }

        :global(.dark) .article-container {
            box-shadow: none;
        }
    }
</style>
