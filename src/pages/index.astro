---
import Base from '../layouts/Base.astro';
import CornerNav from '../components/CornerNav.astro';
import CardProfile from '../components/CardProfile.astro';
import BentoCard from '../components/BentoCard.astro';
import CategoryBadge from '../components/CategoryBadge.astro';
import { pairedCards, cards } from '../data/cards';
import ArticleCard from '../components/ArticleCard.astro';
import { articles } from '../data/articles';

const sortedArticles = [...articles].sort((a, b) => b.dateISO.localeCompare(a.dateISO));
---

<Base
  title="Роман Пуртов. Agentic Engineer & маркетолог & дизайнер."
  description="Agentic Engineer & маркетолог & UX-UI дизайнер из тайги (Томск, МСК+4). Делаю сайты и пишу к ним код 🌲"
>
    <!-- Фоновое видео -->
    <video id="background-video" autoplay muted loop playsinline poster="/images/bg.webp">
        <source src="/videos/bg.mp4" type="video/mp4">
        <img src="/images/bg.webp" alt="Background" style="width: 100%; height: 100%; object-fit: cover;">
    </video>

    <CornerNav />

    <!-- Bento Grid -->
    <div class="lg:flex lg:items-center lg:justify-center lg:px-12 lg:pt-12 xl:px-16 xl:pt-16 2xl:px-20 2xl:pt-20">
    <main class="
        grid gap-3 px-3 pt-3 min-h-screen
        grid-cols-2
        [grid-auto-flow:dense]
        md:grid-cols-4 md:gap-4 md:px-4 md:pt-4
        lg:grid-cols-7 lg:grid-rows-3 lg:[grid-auto-flow:row] lg:min-h-0 lg:p-0 lg:w-full lg:max-w-[90rem]
        xl:gap-5
        2xl:gap-6
    ">
        <CardProfile />

        <!-- Portfolio + Resume (sub-grid wrapper) -->
        <div class="card-pair col-span-2 lg:col-start-3 lg:row-start-3 lg:col-span-3">
            {pairedCards.map(card => <BentoCard card={card} />)}
        </div>

        {cards.map(card => <BentoCard card={card} />)}
    </main>
    </div>

    <!-- Articles -->
    <section class="articles-section mt-3 md:mt-4 xl:mt-5 2xl:mt-6 lg:flex lg:justify-center lg:px-12 xl:px-16 2xl:px-20">
      <div class="px-3 pb-3 md:px-4 md:pb-4 lg:p-0 lg:w-full lg:max-w-[90rem]">
        <h2 class="articles-heading" data-i18n="articles_heading">Кейсы и статьи</h2>
        <div class="articles-grid">
          {sortedArticles.map(article => <ArticleCard article={article} />)}
        </div>
      </div>
    </section>

    <footer class="site-footer py-6 text-center text-sm">
      <p data-i18n="footer_name">Пуртов Роман Григорьевич (самозанятый)</p>
      <p data-i18n="footer_inn">ИНН 702406781541</p>
    </footer>
</Base>
